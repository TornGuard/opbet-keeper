{
  "name": "opbet-keeper",
  "version": "1.0.0",
  "type": "module",
  "description": "OP-BET Keeper Bot: Oracle feed + auto-resolve bets, persisted to Neon PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "pm2": "pm2 start ecosystem.config.cjs",
    "deploy:oracle": "node deploy-oracle.js",
    "balance": "node deploy-oracle.js balance",
    "presale-watcher": "node presale-watcher.js",
    "presale-watcher:mainnet": "IS_MAINNET=1 node presale-watcher.js"
  },
  "dependencies": {
    "@btc-vision/bitcoin": "latest",
    "@btc-vision/transaction": "latest",
    "dotenv": "^17.3.1",
    "opnet": "latest",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "latest",
    "@types/node": "latest",
    "@types/pg": "latest"
  }
}
