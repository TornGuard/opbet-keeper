{
  "name": "blockfeed-keeper",
  "version": "1.0.0",
  "type": "module",
  "description": "BlockFeed Keeper — OPNet oracle price submitter and bet settlement bot",
  "main": "dist/index.js",
  "bin": {
    "blockfeed-keeper": "./bin/keeper.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "pm2": "pm2 start ecosystem.config.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "opnet",
    "bitcoin",
    "keeper",
    "oracle",
    "blockfeed"
  ],
  "dependencies": {
    "@btc-vision/bitcoin": "latest",
    "@btc-vision/transaction": "latest",
    "dotenv": "^17.3.1",
    "opnet": "latest",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "latest",
    "@types/node": "latest",
    "@types/pg": "latest"
  }
}
